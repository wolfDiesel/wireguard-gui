<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WireguardGui.App.Avalonia.ViewModels"
        xmlns:views="using:WireguardGui.App.Avalonia.Views"
        xmlns:controls="using:WireguardGui.App.Avalonia.Controls"
        xmlns:conv="using:WireguardGui.App.Avalonia.Converters"
        x:Class="WireguardGui.App.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Background="{DynamicResource SurfaceCanvasBrush}"
        MinWidth="800"
        MinHeight="500"
        Padding="12">

  <Grid>
    <DockPanel LastChildFill="True">
      <Border DockPanel.Dock="Bottom"
              Classes="island"
              Margin="0,12,0,0"
              Padding="16,10">
        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <Ellipse Width="12" Height="12"
                   Fill="{Binding IsConnected, Converter={x:Static conv:ConnectionBrushConverter.Instance}}" />
          <TextBlock Text="{Binding StatusText}"
                     Classes="text-muted"
                     VerticalAlignment="Center" />
        </StackPanel>
      </Border>

      <Grid ColumnDefinitions="220,*" ColumnSpacing="12">
        <Border Grid.Column="0" Classes="island" Padding="16,20">
          <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="0,0,0,20">
              <StackPanel VerticalAlignment="Center">
                <TextBlock Text="WireGuard" FontWeight="SemiBold" FontSize="15" />
                <TextBlock Text="GUI" Classes="accent-text" FontSize="13" Margin="0,-2,0,0" />
              </StackPanel>
            </StackPanel>

            <StackPanel Spacing="2" ClipToBounds="False">
              <controls:AppButton Variant="Nav"
                      Classes.active="{Binding NavProfilesActive}"
                      Content="{Binding NavProfilesLabel}"
                      Command="{Binding NavigateProfilesCommand}" />
              <controls:AppButton Variant="Nav"
                      Classes.active="{Binding NavSettingsActive}"
                      Content="{Binding NavSettingsLabel}"
                      Command="{Binding NavigateSettingsCommand}" />
            </StackPanel>
          </DockPanel>
        </Border>

        <Border Grid.Column="1"
                Classes="island"
                Padding="20"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
          <ContentControl Content="{Binding CurrentPage}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          VerticalContentAlignment="Stretch" />
        </Border>
      </Grid>
    </DockPanel>

    <views:AppToastHost x:Name="ToastHost"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="20,20,20,0"
                        ZIndex="200" />
  </Grid>
</Window>
