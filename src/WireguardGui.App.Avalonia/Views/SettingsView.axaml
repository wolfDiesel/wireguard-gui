<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WireguardGui.App.Avalonia.ViewModels"
             xmlns:controls="using:WireguardGui.App.Avalonia.Controls"
             xmlns:conv="using:WireguardGui.App.Avalonia.Converters"
             x:Class="WireguardGui.App.Avalonia.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
  <StackPanel Spacing="20">
    <TextBlock Classes="page-title" Text="{Binding Title}" />

    <StackPanel Spacing="8">
      <TextBlock Classes="section-title" Text="{Binding ThemeLabel}" />
      <StackPanel Orientation="Horizontal" Spacing="8">
        <controls:AppButton Variant="OptionChip" Content="{Binding AppearanceDark}"
                Classes.selected="{Binding SelectedAppearance, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=dark}"
                Command="{Binding SelectAppearanceCommand}" CommandParameter="dark" />
        <controls:AppButton Variant="OptionChip" Content="{Binding AppearanceLight}"
                Classes.selected="{Binding SelectedAppearance, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=light}"
                Command="{Binding SelectAppearanceCommand}" CommandParameter="light" />
        <controls:AppButton Variant="OptionChip" Content="{Binding AppearanceSystem}"
                Classes.selected="{Binding SelectedAppearance, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=system}"
                Command="{Binding SelectAppearanceCommand}" CommandParameter="system" />
      </StackPanel>
    </StackPanel>

    <StackPanel Spacing="8">
      <TextBlock Classes="section-title" Text="{Binding AccentLabel}" />
      <ItemsControl ItemsSource="{Binding ColorSchemes}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:PaletteChipViewModel">
            <controls:AppButton Variant="PaletteChip" Margin="0,2"
                    Classes.selected="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).SelectedColorScheme, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={Binding Id}}"
                    Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).SelectColorSchemeCommand}"
                    CommandParameter="{Binding Id}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Border Width="16" Height="16" CornerRadius="4"
                        Background="{Binding PrimaryHex, Converter={x:Static conv:HexToBrushConverter.Instance}}" />
                <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
              </StackPanel>
            </controls:AppButton>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>

    <StackPanel Spacing="8">
      <TextBlock Classes="section-title" Text="{Binding LanguageLabel}" />
      <ItemsControl ItemsSource="{Binding Languages}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel Orientation="Horizontal" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:LanguageOptionViewModel">
            <controls:AppButton Variant="OptionChip" Margin="0,0,8,8" Content="{Binding Label}"
                    Classes.selected="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).SelectedLanguage, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={Binding Code}}"
                    Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).SelectLanguageCommand}"
                    CommandParameter="{Binding Code}" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>

    <StackPanel Spacing="8">
      <TextBlock Classes="section-title" Text="{Binding TrayLabel}" />
      <CheckBox Content="{Binding TrayEnableLabel}" IsChecked="{Binding TrayEnabled}" />
      <CheckBox Content="{Binding TrayMinimizeLabel}" IsChecked="{Binding MinimizeToTray}" />
      <CheckBox Content="{Binding TrayCloseLabel}" IsChecked="{Binding CloseToTray}" />
    </StackPanel>

    <controls:AppButton Variant="Primary" Content="{Binding SaveLabel}" HorizontalAlignment="Left"
            Command="{Binding SaveCommand}" />
  </StackPanel>
</UserControl>
