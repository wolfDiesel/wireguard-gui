<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource SurfaceCanvasBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
    <Setter Property="FontFamily" Value="Inter" />
  </Style>

  <Style Selector="Border.island">
    <Setter Property="Background" Value="{DynamicResource SurfacePanelBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="BoxShadow" Value="0 6 28 0 #6B000000" />
  </Style>

  <Style Selector="Border.island-light">
    <Setter Property="BoxShadow" Value="0 4 18 0 #14000000" />
  </Style>

  <Style Selector="Border.island-inner">
    <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderMutedBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
  </Style>

  <Style Selector="TextBlock.page-title">
    <Setter Property="FontSize" Value="22" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
  </Style>

  <Style Selector="TextBlock.section-title">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource AccentPrimaryBrush}" />
  </Style>

  <Style Selector="TextBlock.text-muted">
    <Setter Property="Foreground" Value="{DynamicResource ForegroundMutedBrush}" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <Style Selector="TextBlock.accent-text">
    <Setter Property="Foreground" Value="{DynamicResource AccentPrimaryBrush}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBox, NumericUpDown">
    <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="10,8" />
  </Style>

  <Style Selector="TextBox:focus, NumericUpDown:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimaryBrush}" />
  </Style>

  <Style Selector="ComboBox">
    <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="MinHeight" Value="36" />
    <Setter Property="Padding" Value="10,8" />
  </Style>

  <Style Selector="AutoCompleteBox">
    <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="MinHeight" Value="36" />
    <Setter Property="Padding" Value="10,8" />
  </Style>

  <Style Selector="AutoCompleteBox:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimaryBrush}" />
  </Style>

  <Style Selector="TextBlock.field-label">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Foreground" Value="{DynamicResource ForegroundMutedBrush}" />
  </Style>

  <Style Selector="TextBlock.field-section">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource ForegroundMutedBrush}" />
    <Setter Property="Margin" Value="0,4,0,8" />
  </Style>

  <Style Selector="Border.settings-panel">
    <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderMutedBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
  </Style>

  <Style Selector="Border.app-toast">
    <Setter Property="Background" Value="#111111" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimaryBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="12" />
    <Setter Property="BoxShadow" Value="0 8 24 0 #73000000" />
  </Style>

  <Style Selector="TextBlock.toast-title">
    <Setter Property="Foreground" Value="{DynamicResource AccentPrimaryBrush}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="LineHeight" Value="16" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.toast-description">
    <Setter Property="Foreground" Value="{DynamicResource ForegroundMutedBrush}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="LineHeight" Value="16" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.toast-icon">
    <Setter Property="Foreground" Value="{DynamicResource AccentPrimaryBrush}" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Width" Value="20" />
    <Setter Property="Height" Value="20" />
    <Setter Property="LineHeight" Value="20" />
    <Setter Property="TextAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TabControl">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="TabItem">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Padding" Value="14,8" />
    <Setter Property="Foreground" Value="{DynamicResource ForegroundMutedBrush}" />
  </Style>

  <Style Selector="TabItem:selected">
    <Setter Property="Foreground" Value="{DynamicResource AccentPrimaryBrush}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="CheckBox">
    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
  </Style>

  <Style Selector="ScrollViewer">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="ListBox">
    <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderMutedBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
  </Style>

</Styles>
